    },
    {
      "parameters": {
        "jsCode": "const EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst PHONE_PATTERN = /^\\+?[0-9]{9,15}$/;\n\nconst REQUIRED_FIELDS = [\n  'companyName',\n  'firstName',\n  'lastName',\n  'nip',\n  'email',\n  'phone',\n];\n\n/**\n * Removes spaces, hyphens, and parentheses from a phone number.\n */\nfunction normalizePhone(value) {\n  return String(value ?? '').replace(/[\\s()-]/g, '');\n}\n\n/**\n * Removes all non-digit characters from a NIP number.\n */\nfunction normalizeNip(value) {\n  return String(value ?? '').replace(/\\D/g, '');\n}\n\n/**\n * Validates the checksum of a Polish NIP number.\n */\nfunction isValidNip(nip) {\n  if (!/^\\d{10}$/.test(nip)) {\n    return false;\n  }\n\n  const weights = [6, 5, 7, 2, 3, 4, 5, 6, 7];\n\n  const checksum = weights.reduce(\n    (sum, weight, index) => sum + Number(nip[index]) * weight,\n    0,\n  );\n\n  const controlDigit = checksum % 11;\n\n  return controlDigit !== 10 && controlDigit === Number(nip[9]);\n}\n\n/**\n * Adds a validation error to a specific field.\n */\nfunction addError(errors, field, message) {\n  if (!errors[field]) {\n    errors[field] = [];\n  }\n\n  errors[field].push(message);\n}\n\n/**\n * Validates a single webhook request body.\n */\nfunction validateWebhookBody(input) {\n  const body =\n    input &&\n    typeof input === 'object' &&\n    input.body &&\n    typeof input.body === 'object' &&\n    !Array.isArray(input.body)\n      ? input.body\n      : {};\n\n  const data = {\n    companyName: String(body.companyName ?? '').trim(),\n    firstName: String(body.firstName ?? '').trim(),\n    lastName: String(body.lastName ?? '').trim(),\n    nip: normalizeNip(body.nip),\n    email: String(body.email ?? '').trim().toLowerCase(),\n    phone: normalizePhone(body.phone),\n  };\n\n  const errors = {};\n\n  // 1. Required fields\n  for (const field of REQUIRED_FIELDS) {\n    if (!data[field]) {\n      addError(errors, field, 'This field is required.');\n    }\n  }\n\n  // 2. Company name\n  if (data.companyName && data.companyName.length < 2) {\n    addError(\n      errors,\n      'companyName',\n      'The company name must contain at least 2 characters.',\n    );\n  }\n\n  if (data.companyName.length > 150) {\n    addError(\n      errors,\n      'companyName',\n      'The company name cannot exceed 150 characters.',\n    );\n  }\n\n  // 3. First name\n  if (data.firstName && data.firstName.length < 2) {\n    addError(\n      errors,\n      'firstName',\n      'The first name must contain at least 2 characters.',\n    );\n  }\n\n  if (data.firstName.length > 100) {\n    addError(\n      errors,\n      'firstName',\n      'The first name cannot exceed 100 characters.',\n    );\n  }\n\n  // 4. Last name\n  if (data.lastName && data.lastName.length < 2) {\n    addError(\n      errors,\n      'lastName',\n      'The last name must contain at least 2 characters.',\n    );\n  }\n\n  if (data.lastName.length > 100) {\n    addError(\n      errors,\n      'lastName',\n      'The last name cannot exceed 100 characters.',\n    );\n  }\n\n  // 5. NIP\n  if (data.nip) {\n    if (!/^\\d{10}$/.test(data.nip)) {\n      addError(\n        errors,\n        'nip',\n        'The NIP number must contain exactly 10 digits.',\n      );\n    } else if (!isValidNip(data.nip)) {\n      addError(\n        errors,\n        'nip',\n        'The NIP number has an invalid checksum.',\n      );\n    }\n  }\n\n  // 6. Email address\n  if (data.email && !EMAIL_PATTERN.test(data.email)) {\n    addError(\n      errors,\n      'email',\n      'Enter a valid email address.',\n    );\n  }\n\n  if (data.email.length > 254) {\n    addError(\n      errors,\n      'email',\n      'The email address cannot exceed 254 characters.',\n    );\n  }\n\n  // 7. Phone number\n  if (data.phone && !PHONE_PATTERN.test(data.phone)) {\n    addError(\n      errors,\n      'phone',\n      'The phone number must contain between 9 and 15 digits and may start with a + sign.',\n    );\n  }\n\n  return {\n    valid: Object.keys(errors).length === 0,\n    data,\n    errors,\n  };\n}\n\nreturn $input.all().map((item, index) => {\n  const input = item.json ?? {};\n  const validation = validateWebhookBody(input);\n\n  return {\n    json: {\n      success: validation.valid,\n      statusCode: validation.valid ? 200 : 422,\n      inputIndex: index,\n      data: validation.data,\n      errors: validation.errors,\n      meta: {\n        executionMode: input.executionMode ?? null,\n        webhookUrl: input.webhookUrl ?? null,\n      },\n    },\n  };\n});"
      },
