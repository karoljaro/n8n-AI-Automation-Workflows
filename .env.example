# Explicitly pinned versions for predictable deployments.
# When updating, keep the same version for n8n and task-runners.
N8N_VERSION=2.26.8
POSTGRES_VERSION=18
# Debian Bookworm: conservative, predictable production base.
# Alternatives: trixie or alpine3.24 (Alpine only if intentionally chosen).
POSTGRES_VARIANT=bookworm

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Generate independent values, e.g.:
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY
N8N_RUNNERS_AUTH_TOKEN=CHANGE_ME_RUNNERS_AUTH_TOKEN

GENERIC_TIMEZONE=Europe/Warsaw

# Local setup / reverse proxy on the same host.
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PUBLIC_URL=http://localhost:5678
N8N_PROXY_HOPS=0

# Example for a public domain behind a single reverse proxy:
# N8N_HOST=n8n.example.com
# N8N_PROTOCOL=https
# N8N_PUBLIC_URL=https://n8n.example.com
# N8N_PROXY_HOPS=1